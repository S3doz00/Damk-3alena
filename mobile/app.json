        "googleMapsApiKey": "AIzaSyCUwCHZGcgaThPEHwXyJNFh2_ts2h2gfUI"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to show nearby blood banks and hospitals.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.damk3alena.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCUwCHZGcgaThPEHwXyJNFh2_ts2h2gfUI"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
